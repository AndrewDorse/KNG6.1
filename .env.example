# =============================================================================
# KNG6 — strategy-1 slice1000 (skew 0.82, streak 22s, cheap 0.19; Polymarket BTC up/down; default 15m only). Copy to .env.
# =============================================================================
POLY_PRIVATE_KEY=0x...
POLY_FUNDER=0x...
POLY_SIGNATURE_TYPE=1
RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

# true = log signals only (no FAK orders). For go-live set false; docker-compose passes POLY_DRY_RUN from host too.
POLY_DRY_RUN=true

# --- Lanes (comma-separated). Default: 15m only. Example dual: KNG6_WINDOW_MINUTES=5,15 ---
KNG6_WINDOW_MINUTES=15

# --- Fast poll so we do not miss the first cheap second after the streak ---
KNG6_POLL_INTERVAL_SECONDS=0.25
KNG6_REQUEST_TIMEOUT_SECONDS=12.0

# --- $1 USDC market buy (FAK) per signal (per slug, see max trades) ---
KNG6_NOTIONAL_USD=1.0
KNG6_MAX_TRADES_PER_SLUG=1
KNG6_NEW_ORDER_CUTOFF_SECONDS=20

# --- Strategy-1 = slice1000 grid (PALADIN sim_streak076_grid_slice1000.py: 1000w, each 100w slice PnL>0) ---
KNG6_SKEW_THR=0.82
KNG6_STREAK_SECONDS=22
KNG6_CHEAP_THR=0.19

KNG6_MARKET_SYMBOL=BTC
KNG6_LOG_LEVEL=INFO
