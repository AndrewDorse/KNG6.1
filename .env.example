# =============================================================================
# KNG6 — strategy-1 streak12_cheap19 (Polymarket BTC up/down 5m + 15m). Copy to .env.
# =============================================================================
POLY_PRIVATE_KEY=0x...
POLY_FUNDER=0x...
POLY_SIGNATURE_TYPE=1
RELAYER_API_KEY=
RELAYER_SECRET=
RELAYER_PASSPHRASE=

# true = log signals only (no FAK orders)
POLY_DRY_RUN=true

# --- Lanes (comma-separated). Default: both 5m and 15m in parallel ---
KNG6_WINDOW_MINUTES=5,15

# --- Fast poll so we do not miss the first cheap second after the streak ---
KNG6_POLL_INTERVAL_SECONDS=0.25
KNG6_REQUEST_TIMEOUT_SECONDS=12.0

# --- $1 USDC market buy (FAK) per signal (per slug, see max trades) ---
KNG6_NOTIONAL_USD=1.0
KNG6_MAX_TRADES_PER_SLUG=1
KNG6_NEW_ORDER_CUTOFF_SECONDS=20

# --- Strategy-1 = X_streak12_076_cheap19 (PALADIN sweep, last-100 pool, May 2026) ---
KNG6_SKEW_THR=0.76
KNG6_STREAK_SECONDS=12
KNG6_CHEAP_THR=0.19

KNG6_MARKET_SYMBOL=BTC
KNG6_LOG_LEVEL=INFO
